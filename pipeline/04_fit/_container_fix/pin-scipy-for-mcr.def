Bootstrap: localimage
From: {{ UPSTREAM_SIF }}

# Generic %post that downgrades scipy / numpy / nilearn so they link
# against a libstdc++ ABI satisfied by MCR R2020b's bundled
# /opt/mcr/v99/sys/os/glnxa64/libstdc++.so.6 (6.0.25, GLIBCXX_3.4.25).
#
# Every container in the `prfanalyze-*` family that's built on
# `prfanalyze-base:3.1.1` shares this bug, so this .def is parameterized
# by the upstream .sif path and reused.
#
# Build via the sibling build.sh:
#   sbatch pipeline/04_fit/_container_fix/build.sh aprf
#   sbatch pipeline/04_fit/_container_fix/build.sh vista
#
# That script supplies UPSTREAM_SIF and chooses the output .sif name.
#
# See ./README.md for the diagnosis writeup and the upstream PR draft.

%post
    set -e
    source /opt/conda/etc/profile.d/conda.sh
    conda activate scientific

    echo "=== before fix ==="
    python -c "import scipy; print('scipy', scipy.__version__)" || true

    pip install --force-reinstall --no-deps \
        "scipy==1.7.3" \
        "numpy==1.21.6" \
        "pandas==1.4.4"
    pip install --force-reinstall --no-deps "nilearn==0.9.2"

    echo "=== after fix ==="
    python -c "import scipy; print('scipy', scipy.__version__)"
    python -c "import numpy;  print('numpy',  numpy.__version__)"
    python -c "import pandas; print('pandas', pandas.__version__)"
    python -c "import nilearn; print('nilearn', nilearn.__version__)"
    python -c "from scipy import linalg, sparse; print('scipy import OK with MCR libstdc++')"

    # NOTE: a JRE-swap (replacing MCR's bundled Java 1.8.0_202 with
    # Temurin 8u432) was tried and did NOT help. The "pure virtual
    # method called" crash MCR exhibits on u24 hosts originates inside
    # libjvm.so's C++ runtime, not the Java bytecode — MCR's compiled
    # launcher is linked against the old libjvm's specific export ABI,
    # so a fresh JRE doesn't restore compatibility. See UPSTREAM_ISSUE.md
    # for the bug report being submitted to vistalab/PRFmodel.

%labels
    MAINTAINER paper_braincoder fork
    FIX_DESCRIPTION scipy/numpy/nilearn pinned for MCR R2020b libstdc++ ABI compat
    FIX_DATE 2026-05-21
    UPSTREAM_SIF {{ UPSTREAM_SIF }}

%runscript
    exec /flywheel/v0/run.sh "$@"
