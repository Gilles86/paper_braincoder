Bootstrap: localimage
From: /shares/zne.uzh/containers/prfanalyze-vista.sif

# Forked image: prfanalyze-vista-fixed
#
# Same problem as prfanalyze-aprf-fixed — the upstream mrVista container
# is built on prfanalyze-base, which has MCR R2020b (libstdc++ 6.0.25,
# max GLIBCXX_3.4.25) and an unpinned scipy in /opt/conda/envs/scientific.
# When the image was built (2023), mamba pulled scipy >= 1.9 which needs
# GLIBCXX_3.4.26+ → ImportError → BIDS app exits in ~7 s with no fit.
#
# Same fix as aPRF: downgrade scipy/numpy/nilearn to versions compiled
# against libstdc++ <= 6.0.25.
#
# Build:
#   sbatch pipeline/04_fit/mrvista/container/build.sh

%post
    set -e
    source /opt/conda/etc/profile.d/conda.sh
    conda activate scientific

    echo "=== before fix ==="
    python -c "import scipy; print('scipy', scipy.__version__)" || true

    pip install --force-reinstall --no-deps \
        "scipy==1.7.3" \
        "numpy==1.21.6"
    pip install --force-reinstall --no-deps "nilearn==0.9.2"

    echo "=== after fix ==="
    python -c "import scipy; print('scipy', scipy.__version__)"
    python -c "import numpy;  print('numpy',  numpy.__version__)"
    python -c "import nilearn; print('nilearn', nilearn.__version__)"
    python -c "from scipy import linalg, sparse; print('scipy import OK with MCR libstdc++')"

%labels
    MAINTAINER paper_braincoder fork
    UPSTREAM garikoitz/prfanalyze-vista:2.3.1_3.1.2
    FIX_DESCRIPTION scipy/numpy/nilearn pinned for MCR R2020b libstdc++ compat
    FIX_DATE 2026-05-21

%runscript
    exec /flywheel/v0/run.sh "$@"
